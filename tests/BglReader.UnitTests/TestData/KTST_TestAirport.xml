<?xml version="1.0" encoding="ISO-8859-1"?>
<FSData
       version="9.0"
       xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
       xsi:noNamespaceSchemaLocation="bglcomp.xsd"
>

       <!-- ============================================================
     KTST - Testfield Regional
     Purpose-built test airport for validating a BGL parser
     against a known-input XML source (rather than blind-testing
     against Legacy/LM-authored BGLs).

     Deliberately exercises:
       - Both runway ends (PRIMARY/SECONDARY) with different
         Markings/Lights/ApproachLights/VASI combinations
       - OffsetThreshold, BlastPad, and Overrun (different surfaces
         than the runway itself, to catch enum decode bugs)
       - An ILS with GlideSlope, DME and a back course flag
       - RunwayStart and airport-level Start entries
       - Taxiway network: TaxiwayPoint (both lat/lon and biasX/Z
         forms), TaxiwayParking (both forms), TaxiwayPath (RUNWAY,
         PARKING, TAXI, PATH types), TaxiName, TaxiwaySign
       - Aprons with Vertex bias data
       - Com frequencies of several types
       - A Helipad
       - Tower placement
     ============================================================ -->

       <Airport
              region="North America"
              country="United States"
              state="Illinois"
              city="Testfield"
              name="Testfield Regional"
              lat="41.35186742"
              lon="-89.15308328"
              alt="199.33918762"
              magvar="-3.5"
              ident="KTST"
              trafficScalar="0.60"
              sloped="FALSE">

              <Tower
                     lat="41.35226742"
                     lon="-89.15258328"
                     alt="215.0" />

              <Com
                     frequency="118.3000"
                     type="TOWER"
                     name="TESTFIELD TOWER" />

              <Com
                     frequency="121.9000"
                     type="GROUND"
                     name="TESTFIELD GROUND" />

              <Com
                     frequency="126.0000"
                     type="ATIS"
                     name="TESTFIELD ATIS" />

              <Com
                     frequency="122.9500"
                     type="UNICOM"
                     name="TESTFIELD UNICOM" />

              <!-- ============================================================
            Runway 18/36 - primary test runway
            Primary end (18): full markings/lights/ALS/VASI/offset threshold
            Secondary end (36): sparser config + blast pad + overrun,
            to exercise asymmetric primary/secondary decoding
            ============================================================ -->
              <Runway
                     lat="41.35184943"
                     lon="-89.15309158"
                     alt="199.33918762"
                     surface="ASPHALT"
                     heading="179.580000"
                     length="6000F"
                     width="100F"
                     number="18"
                     designator="NONE"
                     patternAltitude="304.799988"
                     primaryTakeoff="TRUE"
                     primaryLanding="TRUE"
                     primaryPattern="LEFT"
                     secondaryTakeoff="TRUE"
                     secondaryLanding="TRUE"
                     secondaryPattern="RIGHT">

                     <Markings
                            edges="TRUE"
                            threshold="TRUE"
                            fixedDistance="TRUE"
                            touchdown="TRUE"
                            dashes="TRUE"
                            ident="TRUE"
                            precision="TRUE"
                            edgePavement="TRUE"
                            singleEnd="FALSE"
                            primaryClosed="FALSE"
                            secondaryClosed="FALSE"
                            primaryStol="FALSE"
                            secondaryStol="FALSE" />

                     <Lights
                            center="MEDIUM"
                            edge="HIGH"
                            centerRed="TRUE" />

                     <OffsetThreshold
                            end="PRIMARY"
                            length="250F"
                            width="100F"
                            surface="CONCRETE" />

                     <BlastPad
                            end="SECONDARY"
                            length="200F"
                            width="120F"
                            surface="GRAVEL" />

                     <Overrun
                            end="SECONDARY"
                            length="300F"
                            width="90F"
                            surface="DIRT" />

                     <ApproachLights
                            end="PRIMARY"
                            system="ALSF2"
                            strobes="11"
                            reil="TRUE"
                            touchdown="TRUE"
                            endLights="TRUE" />

                     <ApproachLights
                            end="SECONDARY"
                            system="MALSR"
                            strobes="5"
                            reil="FALSE"
                            touchdown="FALSE"
                            endLights="TRUE" />

                     <Vasi
                            end="PRIMARY"
                            type="PAPI4"
                            side="LEFT"
                            biasX="50F"
                            biasZ="1000F"
                            spacing="45F"
                            pitch="3.00" />

                     <Vasi
                            end="SECONDARY"
                            type="VASI21"
                            side="RIGHT"
                            biasX="-45F"
                            biasZ="1000F"
                            spacing="30F"
                            pitch="3.10" />

                     <Ils
                            lat="41.31184943"
                            lon="-89.15309158"
                            alt="199.33918762"
                            heading="179.580000"
                            frequency="110.3500"
                            end="PRIMARY"
                            range="18N"
                            magvar="-3.5"
                            ident="ITST"
                            width="5.00"
                            name="Testfield Regional ILS RWY 18"
                            backCourse="FALSE">

                            <GlideSlope
                                   lat="41.35104943"
                                   lon="-89.15309158"
                                   alt="222.0F"
                                   pitch="3.00"
                                   range="20N" />

                     </Ils>

                     <RunwayStart
                            type="RUNWAY"
                            lat="41.35184943"
                            lon="-89.15309158"
                            alt="199.33918762"
                            heading="179.580000"
                            end="PRIMARY" />

                     <RunwayStart
                            type="RUNWAY"
                            lat="41.36184943"
                            lon="-89.15309158"
                            alt="199.33918762"
                            heading="359.580000"
                            end="SECONDARY" />

              </Runway>
              <Approach
                     type="ILS"
                     runway="18"
                     designator="NONE"
                     fixType="RUNWAY"
                     fixRegion="K1"
                     fixIdent="RW18"
                     altitude="304.8"
                     heading="179.58"
                     missedAltitude="914.4">

                     <ApproachLegs>

                            <Leg
                                   type="IF"
                                   fixType="WAYPOINT"
                                   fixRegion="K1"
                                   fixIdent="IF18" />

                            <Leg
                                   type="CF"
                                   fixType="RUNWAY"
                                   fixRegion="K1"
                                   fixIdent="RW18"
                                   flyOver="FALSE"
                                   turnDirection="E"
                                   recommendedType="LOCALIZER"
                                   recommendedRegion="K1"
                                   recommendedIdent="ITST"
                                   theta="179.58"
                                   rho="0.0"
                                   distance="5"
                                   magneticCourse="179.58" />

                     </ApproachLegs>

              </Approach>
              <Helipad
                     lat="41.35386742"
                     lon="-89.15108328"
                     alt="199.5F"
                     surface="CONCRETE"
                     heading="0"
                     length="60F"
                     width="60F"
                     type="H"
                     closed="FALSE"
                     transparent="FALSE" />

              <!-- ============================================================
            Taxiway network
            Points 0-4: mix of lat/lon and biasX/biasZ forms, and
            HOLD_SHORT / ILS_HOLD_SHORT / NORMAL types.
            Parking 100-101: one biasX/biasZ GATE, one lat/lon RAMP_GA.
            ============================================================ -->
              <TaxiwayPoint
                     index="0"
                     type="NORMAL"
                     lat="41.35284943"
                     lon="-89.15309158"
                     alt="199.5" />

              <TaxiwayPoint
                     index="1"
                     type="HOLD_SHORT"
                     orientation="FORWARD"
                     alt="199.5"
                     biasX="0.0"
                     biasZ="-300.0" />

              <TaxiwayPoint
                     index="2"
                     type="ILS_HOLD_SHORT"
                     orientation="REVERSE"
                     alt="199.5"
                     biasX="0.0"
                     biasZ="-150.0" />

              <TaxiwayPoint
                     index="3"
                     type="NORMAL"
                     biasX="120.0"
                     biasZ="-320.0"
                     alt="199.5" />

              <TaxiwayPoint
                     index="4"
                     type="NORMAL"
                     lat="41.35300000"
                     lon="-89.15100000"
                     alt="199.5" />

              <TaxiwayParking
                     index="100"
                     lat="41.35320000"
                     lon="-89.15080000"
                     heading="90.0"
                     radius="20.0"
                     type="GATE_SMALL"
                     name="GATE"
                     number="1"
                     airlineCodes="BAW,AAL,UAL"
                     pushBack="BOTH" />

              <TaxiwayParking
                     index="101"
                     lat="41.35320000"
                     lon="-89.15080000"
                     heading="270.0"
                     radius="15.0"
                     type="RAMP_GA_SMALL"
                     name="PARKING"
                     number="2"
                     pushBack="BOTH" />

              <TaxiName
                     index="0"
                     name="A" />

              <TaxiName
                     index="1"
                     name="B" />

              <TaxiwayPath
                     type="RUNWAY"
                     start="0"
                     end="1"
                     width="30.48"
                     weightLimit="500000"
                     surface="ASPHALT"
                     surfaceQuery="DEFAULT"
                     centerLine="TRUE"
                     centerLineLighted="TRUE"
                     leftEdge="SOLID"
                     leftEdgeLighted="TRUE"
                     rightEdge="SOLID"
                     rightEdgeLighted="TRUE"
                     number="18"
                     designator="NONE"
                     flatten="NONE" />

              <TaxiwayPath
                     type="TAXI"
                     start="1"
                     end="2"
                     width="23.0"
                     weightLimit="300000"
                     surface="ASPHALT"
                     surfaceQuery="DEFAULT"
                     centerLine="TRUE"
                     centerLineLighted="FALSE"
                     leftEdge="DASHED"
                     leftEdgeLighted="FALSE"
                     rightEdge="DASHED"
                     rightEdgeLighted="FALSE"
                     name="0" />

              <TaxiwayPath
                     type="PATH"
                     start="2"
                     end="3"
                     width="23.0"
                     weightLimit="300000"
                     surface="ASPHALT"
                     surfaceQuery="DEFAULT"
                     centerLine="TRUE"
                     centerLineLighted="FALSE"
                     name="1" />

              <TaxiwayPath
                     type="PARKING"
                     start="3"
                     end="100"
                     width="20.0"
                     weightLimit="150000"
                     surface="ASPHALT"
                     surfaceQuery="DEFAULT"
                     name="1" />

              <TaxiwayPath
                     type="PATH"
                     start="3"
                     end="4"
                     width="18.0"
                     weightLimit="150000"
                     surface="ASPHALT"
                     surfaceQuery="DEFAULT"
                     name="0" />

              <TaxiwayPath
                     type="PARKING"
                     start="4"
                     end="101"
                     width="18.0"
                     weightLimit="150000"
                     surface="ASPHALT"
                     surfaceQuery="ELEVATION_AND_TYPE"
                     flatten="FLATTEN"
                     name="0" />

              <TaxiwaySign
                     lat="41.35280000"
                     lon="-89.15305000"
                     alt="199.5"
                     altitudeIsAgl="TRUE"
                     pitch="0.00"
                     clampPitch="TRUE"
                     bank="0.00"
                     clampBank="TRUE"
                     heading="90.0"
                     label="l[A]d[B\]m[18-36]"
                     size="SIZE3"
                     justification="LEFT" />

              <Aprons>

                     <Apron
                            surface="CONCRETE"
                            surfaceQuery="DEFAULT"
                            alt="199.5"
                            drawSurface="TRUE"
                            drawDetail="TRUE"
                            flatten="DEFAULT">

                            <Vertex
                                   lat="41.35310000"
                                   lon="-89.15130000" />

                            <Vertex
                                   lat="41.35310000"
                                   lon="-89.15080000" />

                            <Vertex
                                   lat="41.35340000"
                                   lon="-89.15080000" />

                            <Vertex
                                   lat="41.35340000"
                                   lon="-89.15130000" />

                     </Apron>

              </Aprons>

       </Airport>

</FSData>